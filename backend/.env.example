# ──────────────────────────────────────────────────
#  MeetingMind — Backend Environment Variables
# ──────────────────────────────────────────────────

# ----- GROQ (free at console.groq.com) -----
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ----- SUPABASE (free at supabase.com) -----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ----- APP -----
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173

# ----- WHISPER (runs locally, no key needed) -----
# Options: tiny, base, small, medium, large
# 'base' is a good balance of speed and accuracy
WHISPER_MODEL_SIZE=base

# ----- SMTP (optional — leave blank to use mock-send mode) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=meetingmind@demo.com

# ----- SCHEDULER -----
TRACKER_INTERVAL_MINUTES=5

# ----- DEMO MODE (set to true to skip LLM calls) -----
DEMO_MODE=false
